CompileFlags:
  Add:
    # ESP-IDF core headers
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\freertos\FreeRTOS-Kernel\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\freertos\esp_additions\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\freertos\FreeRTOS-Kernel\portable\xtensa\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_common\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\log\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_hw_support\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\hal\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\hal\esp32\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\soc\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\soc\esp32\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\driver\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_driver_gpio\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_driver_i2c\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_driver_ledc\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_adc\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_timer\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_system\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\newlib\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\esp_rom\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\xtensa\include
    - -IC:\Espressif\frameworks\esp-idf-v5.5.4\components\xtensa\esp32\include
    # Target chip defines
    - -DESP_PLATFORM
    - -DIDF_VER="v5.5.4"
    - -DCONFIG_IDF_TARGET_ESP32=1
    - -DCONFIG_FREERTOS_HZ=1000
    # Suppress clangd errors on ESP-IDF asm/builtin macros
    - -Wno-unknown-attributes
    - -Wno-unused-command-line-argument
  Compiler: clang
